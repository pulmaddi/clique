# ─────────────────────────────────────────────────────────────
# Clique — root example environment.
# Copy to .env for local dev. NEVER commit a real .env (see .gitignore).
# App-specific copies live in apps/api/.env and apps/mobile/.env.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://clique:clique@localhost:5432/clique?schema=public

# --- Redis (cache, pub/sub, BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300

# --- LiveKit (WebRTC media) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-32chars-min

# --- Razorpay (payments) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxx

# --- Platform config ---
PLATFORM_COMMISSION_PERCENT=15
DEFAULT_CURRENCY=INR

# --- Notifications (FCM) ---
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

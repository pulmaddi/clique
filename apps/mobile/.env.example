# apps/mobile environment. Copy to apps/mobile/.env and fill in.
# EXPO_PUBLIC_* vars are inlined into the app at build time.
# These are the PUBLIC (anon) Supabase keys — safe in the client; RLS protects data.
# Get them from Supabase: Project Settings → API. See supabase/README.md.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
